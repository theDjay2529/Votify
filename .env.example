# ============================================================
#  🔧 VOTIFY — Environment Variables
# ============================================================
#  Copy this file to .env and fill in your real values:
#    cp .env.example .env
# ============================================================

# Supabase credentials (supabase.com → Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Host screen PIN (only the event host should know this)
VITE_HOST_PIN=00000

# Deployed site URL (set after deploying to Netlify/Vercel)
VITE_DEPLOYED_URL=
